# Скопируйте в .env и подставьте свои значения. Файл .env не коммитить в git.
# На сервере можно задать переменные в systemd или в shell перед запуском.
# Токены из чатов и скриншотов считать скомпрометированными — в BotFather: Revoke token.

BOT_TOKEN=your_telegram_bot_token_here
# или
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

DEEPSEEK_API_KEY=your_deepseek_api_key_here

# rent_bot.py
# RENT_BOT_ADMIN_ID=123456789

# --- Freqtrade: Telegram RPC (переменные перекрывают user_data/config.json) ---
# Отдельный бот @BotFather только для Freqtrade (не путать с BOT_TOKEN для main.py).
# FREQTRADE__TELEGRAM__ENABLED=true
# FREQTRADE__TELEGRAM__TOKEN=your_freqtrade_bot_token
# FREQTRADE__TELEGRAM__CHAT_ID=your_numeric_chat_id
# Необязательно: список user_id, кому разрешены команды (иначе только chat_id)
# FREQTRADE__TELEGRAM__AUTHORIZED_USERS=["123456789"]
# chat_id: /start боту, затем getUpdates — "chat":{"id":...}
#
# --- Freqtrade: REST API + FreqUI (пароли лучше переопределить здесь) ---
# FREQTRADE__API_SERVER__ENABLED=true
# FREQTRADE__API_SERVER__LISTEN_IP_ADDRESS=127.0.0.1
# FREQTRADE__API_SERVER__LISTEN_PORT=8080
# FREQTRADE__API_SERVER__USERNAME=freqtrader
# FREQTRADE__API_SERVER__PASSWORD=your_strong_api_password
# FREQTRADE__API_SERVER__JWT_SECRET_KEY=long_random_hex_string
# FREQTRADE__API_SERVER__WS_TOKEN=random_ws_token_string

# Опционально:
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_VISION_MODEL=deepseek-chat
#
# --- VK calendar mirror (vk_calendar_server.py) ---
# VK_CALENDAR_HOST=0.0.0.0
# VK_CALENDAR_PORT=8090
# VK_CALENDAR_DEFAULT_DAYS=14
# VK_RENT_DB_PATH=/opt/telegram-bot/rent_bot.db
